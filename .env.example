# =============================================================
# KIRA - Quantitative Trading Platform
# Environment Configuration Template
#
# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your Upstox API credentials (required for live data)
# 3. Change any default passwords before deploying publicly
# =============================================================

# --- INFRASTRUCTURE SECRETS ---

# Postgres Metadata DB
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme123
POSTGRES_DB=quant_platform

# MinIO Object Storage
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme123

# QuestDB (Defaults - these are QuestDB's built-in defaults)
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest

# Redis
REDIS_HOST=redis_state
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka_bus:9092

# --- UPSTOX API CREDENTIALS ---
# Get these from: https://developer.upstox.com/
# The ACCESS_TOKEN expires every 24 hours and must be renewed daily.
# See README.md for the full token renewal guide.

UPSTOX_API_KEY=YOUR_UPSTOX_API_KEY_HERE
UPSTOX_API_SECRET=YOUR_UPSTOX_API_SECRET_HERE
UPSTOX_REDIRECT_URI=http://localhost
UPSTOX_ACCESS_TOKEN=YOUR_UPSTOX_ACCESS_TOKEN_HERE

# --- APP CONFIGURATION ---

# Set to 'false' for live paper-trading, 'true' for backtesting mode
BACKTEST_MODE=false
LOG_LEVEL=INFO

# Strategy Configuration (JSON)
STRATEGY_PARAMS={"profit_target": 0.003, "trailing_stop": 0.002, "cooldown": 30}

# Transaction Cost Model
BROKERAGE_FLAT=20.0
BROKERAGE_PCT=0.0003

# --- DEPLOYMENT ---
# Your GitHub username (lowercase) and repo name — used to pull images from GHCR
# Example: if your repo is https://github.com/Suprath/KIRA → set to 'suprath/kira'
GITHUB_REPOSITORY_LOWER=suprath/kira
APP_VERSION=stable
